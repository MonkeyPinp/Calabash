{
  "identifier": "default",
  "description": "Default desktop permissions for the Calabash main window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:default",
    "fs:allow-mkdir",
    "fs:allow-write-file",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "opener:default",
    "sql:default",
    "sql:allow-execute",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$APPDATA/backups" },
        { "path": "$APPDATA/backups/**" }
      ]
    }
  ]
}
