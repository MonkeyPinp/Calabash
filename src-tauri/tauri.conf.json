{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Calabash",
  "version": "0.5.3",
  "identifier": "studio.guesswhat.calabash",
  "build": {
    "beforeDevCommand": "npm --prefix app run dev -- --host 127.0.0.1",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm --prefix app run build",
    "frontendDist": "../app/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Calabash",
        "width": 1440,
        "height": 960,
        "minWidth": 1024,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "publisher": "Guesswhat Studio",
    "shortDescription": "Spoiler-safe relationship boards for detective fiction readers.",
    "longDescription": "Calabash is a local-first case-file board for tracking characters, aliases, clues, relationships, and theories while reading detective fiction.",
    "copyright": "Copyright (c) 2026 Guesswhat Studio",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
